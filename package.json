{
  "name": "nucleo-ai",
  "version": "0.1.0",
  "description": "CLI and Codex skill for searching, selecting, and integrating Nucleo icons.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/merill/nucleo-ai.git"
  },
  "homepage": "https://github.com/merill/nucleo-ai",
  "bugs": {
    "url": "https://github.com/merill/nucleo-ai/issues"
  },
  "type": "module",
  "bin": {
    "nucleo-icons": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "skill"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist artifacts",
    "prepack": "npm run build",
    "validate:skill": "node ./scripts/validate-skill.mjs",
    "package:skill": "mkdir -p artifacts && tar -czf artifacts/nucleo-icons-skill.tgz -C skill nucleo-icons && cd skill && zip -rq ../artifacts/nucleo-icons-skill.zip nucleo-icons",
    "package:npm": "mkdir -p artifacts && npm pack --pack-destination artifacts",
    "package:release": "npm run clean && npm run build && npm run validate:skill && npm run package:npm && npm run package:skill",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "nucleo",
    "icons",
    "react",
    "svg",
    "codex",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cheerio": "^1.1.0",
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "fuse.js": "^7.1.0",
    "svgo": "^4.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
